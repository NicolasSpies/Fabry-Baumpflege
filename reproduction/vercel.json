{
    "rewrites": [
        {
            "source": "/cms/:path*",
            "destination": "https://cms.fabry-baumpflege.be/wp-json/:path*"
        },
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/api/render?path=/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                }
            ]
        },
        {
            "source": "/cms/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=300, stale-while-revalidate=600"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}